{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "start": "node .output/server/index.mjs",
    "generate": "nuxt generate",
    "preview": "pnpm run build && wrangler dev",
    "postinstall": "nuxt prepare",
    "prepare:husky": "cd .. && node portfolio/node_modules/husky/bin.js portfolio/.husky",
    "check": "npx biome check .",
    "write": "npx biome check --write .",
    "slint": "npx stylelint \"**/**/*.scss\"",
    "slint:fix": "npx stylelint \"**/**/*.scss\" --fix",
    "tests": "npx vitest run",
    "test:coverage": "npx vitest run --coverage",
    "test:watch": "npx vitest",
    "typeslint": "tsc --noemit",
    "wrangler": "npx wrangler deploy",
    "deploy": "pnpm run build && wrangler deploy"
  },
  "dependencies": {
    "@iconify-json/mdi": "1.2.3",
    "@nuxt/icon": "1.15.0",
    "@nuxt/kit": "4.3.1",
    "@nuxtjs/critters": "0.9.0",
    "@nuxtjs/google-fonts": "3.2.0",
    "@nuxtjs/robots": "5.2.10",
    "@nuxtjs/sitemap": "7.2.10",
    "nuxt": "3.21.1",
    "vue": "3.5.27",
    "nuxt-schema-org": "5.0.5",
    "nuxt-seo-utils": "7.0.11",
    "nuxt-vitalizer": "0.10.0",
    "vue-router": "4.5.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@nuxt/fonts": "0.11.2",
    "@nuxt/test-utils": "3.21.0",
    "@nuxtjs/html-validator": "2.1.0",
    "@nuxtjs/stylelint-module": "5.2.1",
    "happy-dom": "20.0.10",
    "html-validate": "9.5.3",
    "husky": "9.1.7",
    "nitro-cloudflare-dev": "^0.2.2",
    "nuxt-link-checker": "4.3.0",
    "sass": "1.87.0",
    "stylelint": "16.19.1",
    "stylelint-config-standard-scss": "14.0.0",
    "typescript": "5.8.3",
    "vitest": "3.2.0",
    "wrangler": "4.81.1"
  }
}
